{
  "info": {
    "name": "Task Timer API",
    "_postman_id": "task-timer-collection-v1",
    "description": "Colección completa para probar todos los endpoints de Task Timer",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "",
      "type": "string",
      "description": "ID de la tarea (se llena automáticamente al crear una)"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Verifica que el servidor y la conexión a MongoDB estén activos."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Get All Tasks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (Array.isArray(data) && data.length > 0) {",
                  "  pm.collectionVariables.set('task_id', data[0].id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "tasks"]
            },
            "description": "Obtiene todas las tareas activas. También ejecuta la limpieza automática de tareas DONE con más de 10 segundos (las mueve al historial)."
          },
          "response": []
        },
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.id) {",
                  "  pm.collectionVariables.set('task_id', data.id);",
                  "  console.log('task_id guardado:', data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Mi tarea de prueba\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tasks",
              "host": ["{{base_url}}"],
              "path": ["api", "tasks"]
            },
            "description": "Crea una nueva tarea en estado 'pending'. El ID se guarda automáticamente en la variable task_id."
          },
          "response": []
        },
        {
          "name": "Start Task (pending → inprogress)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"inprogress\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tasks", "{{task_id}}"]
            },
            "description": "Cambia el estado a 'inprogress' y guarda el campo startedAt en la base de datos."
          },
          "response": []
        },
        {
          "name": "Finish Task (inprogress → done)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tasks", "{{task_id}}"]
            },
            "description": "Cambia el estado a 'done', calcula y guarda inProgressDuration (segundos en progreso) y doneAt. Después de 10 segundos, el próximo GET la mueve al historial automáticamente."
          },
          "response": []
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "tasks", "{{task_id}}"]
            },
            "description": "Elimina la tarea y la mueve al historial con reason='deleted'."
          },
          "response": []
        }
      ]
    },
    {
      "name": "History",
      "item": [
        {
          "name": "Get History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/history",
              "host": ["{{base_url}}"],
              "path": ["api", "history"]
            },
            "description": "Obtiene todo el historial ordenado por fecha de archivado (más reciente primero). Incluye tareas eliminadas (reason='deleted') y completadas (reason='done')."
          },
          "response": []
        }
      ]
    }
  ]
}
